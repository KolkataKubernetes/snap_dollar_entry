#   width = 9,
#   height = 6
# )
#
# 4) 06_retail_format_pre_post (with rural/non-rural breakout)
format_event <- merge(
format_stock,
unique(event2[, .(county_fips, eventYear2 = minYear2)]),
by = "county_fips",
all.x = FALSE
)
format_event[, tau := year - eventYear2]
format_event <- format_event[tau %in% -3:3]
format_event <- merge(format_event, rucc, by = "county_fips", all.x = TRUE)
format_event[is.na(is_rural), is_rural := FALSE]
format_event[, county_group := fifelse(is_rural, "Rural counties", "Non-rural counties")]
format_growth <- format_event[, .(
pre_stock = mean(stock[tau %in% -3:-1], na.rm = TRUE),
post_stock = mean(stock[tau %in% 0:3], na.rm = TRUE)
), by = .(county_fips, format, county_group)]
format_growth[, log_growth := log1p(post_stock) - log1p(pre_stock)]
format_growth_summary <- format_growth[, .(
approx_pct_growth = 100 * (exp(mean(log_growth, na.rm = TRUE)) - 1)
), by = .(format, county_group)]
format_growth_summary[, format := factor(format, levels = names(format_colors))]
format_growth_summary[, county_group := factor(county_group, levels = c("Rural counties", "Non-rural counties"))]
p_format_growth <- ggplot(
format_growth_summary,
aes(x = format, y = approx_pct_growth, fill = county_group)
) +
geom_col(width = 0.65, alpha = 0.9, position = position_dodge(width = 0.75)) +
scale_fill_manual(values = rural_split_colors) +
labs(
title = "06 Retail Format Pre/Post Conferral Growth",
subtitle = "Treated counties, approximate percent growth from tau -3:-1 to tau 0:3, by rural status",
x = NULL,
y = "Approx. percent growth",
fill = NULL
) +
theme_im(base_size = 13)
save_plot_safe(
p_format_growth,
file.path(ppt_dir, "06_retail_format_pre_post.jpeg"),
"Retail format pre/post conferral growth JPEG",
width = 9,
height = 6
)
