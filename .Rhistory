# 2017: 6.5, over May   '14 to Apr '16   (2)
# 2016: 6.9, over May   '13 to Apr '15 (2)
# 2015: 8.1, over Jan   '13 to Dec '14 (1)
# 2014: 9.4, over Nov   '11 to Oct '13 (2)
# 2013: State-wide
# 2012: State-wide
# 2011: State-wide
#///////////////////////////////////////////////////////////////////////////////
#----  2. SNAP Counts                                                       ----
#///////////////////////////////////////////////////////////////////////////////
tab = storeCount[, .(count=sum(count)), by = .(chain, year)]
tab = tab[chain %in% c('chain_dollar_general',
'chain_family_dollar',
'chain_dollar_tree')]
ggplot(tab, aes(x=year, y=count, group=chain, color=chain)) +
geom_line() +
geom_point() +
scale_x_continuous(breaks = unique(tab$year)) +
theme(legend.position = "bottom",
axis.text.x = element_text(angle = 90, vjust = 0.5, hjust=1))
#///////////////////////////////////////////////////////////////////////////////
#----  3. Cleaning the data                                                 ----
#///////////////////////////////////////////////////////////////////////////////
# Geography
setnames(aba, 'FIPS', 'county_fips')
treated_counties = unique(aba$county_fips)
# Only keep treated counties
aba <- aba[!is.na(county_fips)]
aba <- unique(aba[,.(county_fips, year=YEAR, countyname=LOC, type = LOC_TYPE, Value=1)])
counties = aba$county_fips
# Entry counts ---------------------------------------------------------------
table(snap$county_fips)
entry <- snap[, .(entry=.N), by='authorization_year,county_fips,chain']
setnames(entry, 'authorization_year', 'year')
entry <- dcast(entry, year + county_fips ~ chain, value.var = 'entry', fill=0)
entry <- entry[, total_ds := chain_dollar_general + chain_dollar_tree + chain_family_dollar]
entry <- entry[, state:=substr(county_fips, 1,2)]
entry <- entry[, state:=as.numeric(county_fips) %/% 1000]
grid = CJ(county_fips = as.numeric(acs03$GEOID_COUNTY),
year= 2000:2020,
unique = TRUE)
entry = merge(grid, entry, by=c('county_fips','year'), all.x=T)
# Store Counts -----------------------------------------------------------------
sc = copy(storeCount)
sc[, chain:=paste0(chain, '_count')]
sc = sc[!chain %in% c("chain_family_dollar_count",
"chain_dollar_general_count",
"chain_dollar_tree_count"), chain := 'chain_nods_count']
sc = sc[, .(count=sum(count)), by='county_fips,chain,year']
sc = dcast(sc, year + county_fips ~ chain, value.var = 'count', fill=0)
sc = sc[, total_count:=chain_dollar_general_count+
chain_dollar_tree_count+
chain_family_dollar_count]
sc = sc[, county_fips:=as.numeric(county_fips)]
# Merge entry and aba ----------------------------------------------------------
aba <- merge(aba, entry, by=c('year', 'county_fips'), all.y=T)
setnames(aba, 'Value', 'treatment')
aba <- merge(aba, sc, by=c('year', 'county_fips'), all.x=T)
aba[is.na(aba)] <- 0
length(unique(aba$county_fips))
# Add controls -----------------------------------------------------------------
aba <- merge(aba, fp[,.(county_fips, year, income, rent)], all.x=T,
by=c('year', 'county_fips'))
length(unique(aba$county_fips))
# Event Study Variables --------------------------------------------------------
event1 = aba[treatment==1]
event1 = event1[, minYear1:=min(year), by='county_fips']
event1 = event1[minYear1==year]
event2 = aba[treatment==1 & year>=2014 & type == 'County']
event2 = event2[, minYear2:=min(year), by='county_fips']
event2 = event2[minYear2==year]
aba = merge(aba, event1[,.(county_fips, eventYear1=minYear1)], by='county_fips', all.x=T)
length(unique(aba$county_fips))
aba = aba[year %in% 2010:2013, treatment:=1]
aba = aba[!county_fips %in% treated_counties, `:=`(eventYear1=2010)]
aba = aba[, tau1:= year - eventYear1]
aba = merge(aba, event2[,.(county_fips, eventYear2=minYear2)], by='county_fips', all.x=T)
aba = aba[, tau2:= year - eventYear2]
length(unique(aba$county_fips))
# Treated ----------------------------------------------------------------------
aba = aba[, treated:=county_fips %in% treated_counties]
# Merge wage -------------------------------------------------------------------
aba = merge(aba, wages, by=c('county_fips', 'year'), all.x=T)
aba = aba[, wage_st := mean(wage,na.rm=T), by='year']
aba = aba[is.na(wage), wage:=wage_st]
# aba = aba[county_fips!=0]
length(unique(aba$county_fips))
# Merge total of households ----------------------------------------------------
aba = merge(aba, acs03[,.(county_fips=as.numeric(GEOID_COUNTY), year, totalHH, meanInc, medianInc)],
by=c('county_fips', 'year'),
all.x=T)
length(unique(aba$county_fips))
aba = merge(aba, population[,.(county_fips=GEOID, year, population=estimate)],
by=c('county_fips', 'year'),
all.x=T)
length(unique(aba$county_fips))
# Merge the unemployment
aba = merge(aba, u[,.(county_fips=GEOID, year, urate=unemployment_rate)],
by=c('county_fips', 'year'),
all.x=T)
length(unique(aba$county_fips))
#///////////////////////////////////////////////////////////////////////////////
#----  4. Workshop Descriptives (County-level)                              ----
#///////////////////////////////////////////////////////////////////////////////
workshop_tag <- "20260309"
run_event_study <- FALSE
ds_chains <- c("chain_dollar_general", "chain_dollar_tree", "chain_family_dollar")
ppt_dir <- file.path("figures", paste0("workshop_", workshop_tag, "_ppt_jpeg"))
dir.create(ppt_dir, recursive = TRUE, showWarnings = FALSE)
# Match formatting approach from 2026_02_08_pitchbook.qmd
theme_im <- function(base_size = 12) {
theme_minimal(base_size = base_size) +
theme(
plot.title.position = "plot",
plot.caption.position = "plot",
panel.grid.minor = element_blank(),
panel.grid.major.x = element_line(linewidth = 0.3),
panel.grid.major.y = element_line(linewidth = 0.3),
legend.position = "top",
legend.title = element_text(face = "bold"),
plot.title = element_text(face = "bold"),
axis.title = element_text(face = "bold")
)
}
format_colors <- c(
"Dollar stores" = "#c5050c",
"Convenience stores" = "#0072B2",
"Supermarkets" = "grey60",
"Multi-category" = "black"
)
waiver_colors <- c("Ever county-waived" = "#c5050c", "Never county-waived" = "#0072B2")
rural_split_colors <- c("Rural counties" = "#0072B2", "Non-rural counties" = "grey60")
treated_counties_2014plus <- unique(event2$county_fips)
county_panel <- unique(entry[, .(county_fips, year, total_ds)])
county_panel <- merge(
county_panel,
unique(event2[, .(county_fips, eventYear2 = minYear2)]),
by = "county_fips",
all.x = TRUE
)
county_panel[, ever_county_waived := county_fips %in% treated_counties_2014plus]
rucc <- as.data.table(readxl::read_excel('/Users/indermajumdar/Library/CloudStorage/Box-Box/SNAP Dollar Entry/data/0_inputs/0_7_Ruralurbancontinuumcodes2023.xlsx'))
rucc <- unique(rucc[, .(county_fips = as.numeric(FIPS), is_rural = RUCC_2023 >= 4)])
# Store stock panel for dollar stores
ds_stock_raw <- storeCount[chain %in% ds_chains,
.(ds_stock_count = sum(count, na.rm = TRUE)),
by = .(county_fips = as.numeric(county_fips), year)]
ds_stock <- merge(county_panel[, .(county_fips, year, ever_county_waived, eventYear2)],
ds_stock_raw,
by = c("county_fips", "year"),
all.x = TRUE)
ds_stock[is.na(ds_stock_count), ds_stock_count := 0]
# Common format panel
multi_category_chains <- if (any(storeCount$chain == "chain_multi_category")) {
c("chain_multi_category")
} else {
c("chain_wal-mart", "chain_target")
}
format_groups <- list(
"Dollar stores" = ds_chains,
"Convenience stores" = c("chain_convenience_store"),
"Supermarkets" = c("chain_super_market"),
"Multi-category" = multi_category_chains
)
format_stock <- rbindlist(lapply(names(format_groups), function(fmt) {
format_tmp <- storeCount[chain %in% format_groups[[fmt]],
.(stock = sum(count, na.rm = TRUE)),
by = .(county_fips = as.numeric(county_fips), year)]
format_tmp[, format := fmt]
format_tmp
}), fill = TRUE)
format_grid <- CJ(
county_fips = unique(county_panel$county_fips),
year = 2000:2020,
format = names(format_groups),
unique = TRUE
)
format_stock <- merge(format_grid, format_stock, by = c("county_fips", "year", "format"), all.x = TRUE)
format_stock[is.na(stock), stock := 0]
# 1) Retailer format stock index
format_trend <- format_stock[year %in% 2010:2020,
.(mean_stock = mean(stock, na.rm = TRUE)),
by = .(year, format)]
format_trend[, base_2010 := mean_stock[year == 2010], by = format]
format_trend[, stock_index_2010 := fifelse(base_2010 == 0, NA_real_, 100 * mean_stock / base_2010)]
p_format_index <- ggplot(format_trend, aes(x = year, y = stock_index_2010, color = format, group = format)) +
geom_line(linewidth = 1.1) +
geom_point(size = 2) +
scale_color_manual(values = format_colors, breaks = names(format_colors)) +
scale_x_continuous(breaks = 2010:2020) +
labs(
title = "Retailer Format Stock Index",
subtitle = "County-average stock index (2010 = 100), all counties",
x = "Year",
y = "Stock index (2010 = 100)",
color = NULL
) +
theme_im(base_size = 13)
# save_plot_safe(
#   p_format_index,
#   file.path(ppt_dir, "retailer_format_stock_index.jpeg"),
#   "Retailer format stock index (all counties) JPEG",
#   width = 10,
#   height = 6
# )
# 2) Retailer format stock index - rural counties only
format_stock_rural <- merge(format_stock, rucc, by = "county_fips", all.x = TRUE)
format_stock_rural[is.na(is_rural), is_rural := FALSE]
format_trend_rural <- format_stock_rural[is_rural == TRUE & year %in% 2010:2020,
.(mean_stock = mean(stock, na.rm = TRUE)),
by = .(year, format)]
format_trend_rural[, base_2010 := mean_stock[year == 2010], by = format]
format_trend_rural[, stock_index_2010 := fifelse(base_2010 == 0, NA_real_, 100 * mean_stock / base_2010)]
p_format_index_rural <- ggplot(format_trend_rural, aes(x = year, y = stock_index_2010, color = format, group = format)) +
geom_line(linewidth = 1.1) +
geom_point(size = 2) +
scale_color_manual(values = format_colors, breaks = names(format_colors)) +
scale_x_continuous(breaks = 2010:2020) +
labs(
title = "Retailer Format Stock Index - Rural Counties",
subtitle = "County-average stock index (2010 = 100), RUCC 4-9 counties",
x = "Year",
y = "Stock index (2010 = 100)",
color = NULL
) +
theme_im(base_size = 13)
# save_plot_safe(
#   p_format_index_rural,
#   file.path(ppt_dir, "retailer_format_stock_index_rural.jpeg"),
#   "Retailer format stock index (rural counties only) JPEG",
#   width = 10,
#   height = 6
# )
# 3) County waivers by year: rural, urban, total
waiver_county_raw <- fread('/Users/indermajumdar/Research/snap_dollar_entry/legacy/2_processed_data/waiver_data_consolidated_long.csv')
waiver_county_raw <- unique(
waiver_county_raw[!is.na(FIPS) & LOC_TYPE == "County",
.(county_fips = as.numeric(FIPS), year = YEAR)]
)
waiver_county_raw <- merge(waiver_county_raw, rucc, by = "county_fips", all.x = TRUE)
waiver_county_raw[is.na(is_rural), is_rural := FALSE]
waiver_by_group <- waiver_county_raw[, .(
waived_counties = uniqueN(county_fips)
), by = .(year, county_group = fifelse(is_rural, "Rural counties", "Urban counties"))]
waiver_total <- waiver_county_raw[, .(
waived_counties = uniqueN(county_fips)
), by = year]
waiver_total[, county_group := "Total counties"]
waiver_year_ts <- rbindlist(list(waiver_by_group, waiver_total), use.names = TRUE)
waiver_year_ts <- waiver_year_ts[order(year, county_group)]
waiver_ts_colors <- c(
"Rural counties" = "#0072B2",
"Urban counties" = "grey60",
"Total counties" = "black"
)
p_conferral_growth <- ggplot(
waiver_year_ts,
aes(x = year, y = waived_counties, color = county_group, group = county_group)
) +
geom_line(linewidth = 1.1) +
geom_point(size = 2) +
scale_color_manual(values = waiver_ts_colors) +
scale_x_continuous(breaks = sort(unique(waiver_year_ts$year))) +
labs(
title = "County ABAWD Waivers by Year",
subtitle = "Counts of counties with county-level waivers, split by rural vs urban",
x = "Year",
y = "Number of counties with waivers",
color = NULL
) +
theme_im(base_size = 13)
